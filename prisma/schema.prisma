generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String?
  passwordHash            String?
  emailVerified           DateTime?
  image                   String?
  notificationPrefs       Json?
  preferredOrganizationId String?
  orgCooldownUntil        DateTime?
  isInvitedUser           Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  memberships          Membership[]
  uploads              Upload[]
  reports              Report[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  cnpj           String?   @unique
  niche          String?
  monthlyRevenue Decimal?  @db.Decimal(12, 2)
  employeeCount  Int?
  plan                 String    @default("free")
  trialEndsAt          DateTime?
  planExpiresAt        DateTime?
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  financePinHash        String?
  financePinAttempts    Int       @default(0)
  financePinLockedUntil DateTime?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  memberships       Membership[]
  onboardingProfile OnboardingProfile?
  uploads           Upload[]
  transactions      Transaction[]
  analyses          Analysis[]
  alerts            Alert[]
  recommendations   Recommendation[]
  scoreSnapshots    ScoreSnapshot[]
  reports           Report[]
  invites           Invite[]
}

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("owner")
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model OnboardingProfile {
  id                  String    @id @default(cuid())
  organizationId      String    @unique
  businessType        String?
  niche               String?
  monthlyRevenueRange String?
  employeeCountRange  String?
  financialTools      String[]
  mainPainPoints      String[]
  primaryGoal         String?
  currentControl      String?
  completed           Boolean   @default(false)
  completedAt         DateTime?
  createdAt           DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Upload {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  fileName       String
  fileUrl        String
  fileSize       Int?
  fileType       String
  status         String    @default("processing")
  rowsCount      Int?
  periodStart    DateTime?
  periodEnd      DateTime?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  transactions Transaction[]
  analyses     Analysis[]
}

model Transaction {
  id             String   @id @default(cuid())
  organizationId String
  uploadId       String
  date           DateTime
  description    String
  amount         Decimal  @db.Decimal(12, 2)
  categorySlug   String?
  vendor         String?
  isRecurring    Boolean  @default(false)
  recurrenceType String?
  tags           String[]
  rawData        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  upload       Upload       @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

model Analysis {
  id             String    @id @default(cuid())
  organizationId String
  uploadId       String
  status         String    @default("pending")
  periodStart    DateTime?
  periodEnd      DateTime?
  totalExpenses  Decimal?  @db.Decimal(12, 2)
  totalIncome    Decimal?  @db.Decimal(12, 2)
  netResult      Decimal?  @db.Decimal(12, 2)
  score          Int?
  savingsMin     Decimal?  @db.Decimal(12, 2)
  savingsMax     Decimal?  @db.Decimal(12, 2)
  summary        Json?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  upload          Upload           @relation(fields: [uploadId], references: [id])
  insights        Insight[]
  alerts          Alert[]
  recommendations Recommendation[]
  scoreSnapshots  ScoreSnapshot[]
  reports         Report[]
}

model Insight {
  id          String   @id @default(cuid())
  analysisId  String
  type        String
  category    String?
  title       String
  description String
  impact      String?
  urgency     String?
  amount      Decimal? @db.Decimal(12, 2)
  status      String   @default("open")
  metadata    Json?
  createdAt   DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  analysisId     String
  type           String
  severity       String
  title          String
  message        String
  amount         Decimal? @db.Decimal(12, 2)
  isRead         Boolean  @default(false)
  isDismissed    Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analysis     Analysis     @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id              String   @id @default(cuid())
  organizationId  String
  analysisId      String
  title           String
  description     String
  rationale       String?
  impact          String?
  urgency         String?
  difficulty      String?
  savingsEstimate Decimal? @db.Decimal(12, 2)
  category        String?
  status          String   @default("pending")
  priority        Int      @default(0)
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analysis     Analysis     @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  analysisId     String
  score          Int
  subscores      Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analysis     Analysis     @relation(fields: [analysisId], references: [id])
}

model Report {
  id             String    @id @default(cuid())
  organizationId String
  analysisId     String
  userId         String
  title          String
  fileUrl        String?
  status         String    @default("generating")
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  analysis     Analysis     @relation(fields: [analysisId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model Invite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           String    @default("member")
  token          String    @unique @default(cuid())
  invitedByName  String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
}